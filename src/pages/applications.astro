---
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { allProjects } from "../data/projects.js";
import { applicationCards, company } from "../data/site.js";

const trustStats = [
  { value: "50,000+", label: "Installations" },
  { value: "12+", label: "Years Operation" },
  { value: "75%", label: "Railway Market Share" },
  { value: "30+", label: "Countries" },
];

const customers = [
  "TBEA",
  "XD Electric",
  "Baoding Tianwei Baobian",
  "Pinggao Group",
  "Yunnan Transformer",
  "Shandong Dachi",
  "Jiangsu Yawei",
  "State Grid",
  "Longyuan Power",
];
---

<BaseLayout title={`Reference Projects | ${company.name}`}>
  <main>
    <PageHero
      eyebrow="Reference Projects"
      title="Proven in Critical Power Infrastructure Worldwide"
      text="50,000+ bushings installed across railways, substations, solar farms, hydropower and industrial plants. Trusted by TBEA, XD Electric, State Grid and more."
      image="/assets/application-transformer-sites.jpg"
    />

    <section class="trust-row" aria-label="Reference project trust signals">
      {trustStats.map((item) => (
        <article>
          <div>
            <strong>{item.value}</strong>
            <p>{item.label}</p>
          </div>
        </article>
      ))}
    </section>

    <section class="section cases-preview">
      <div class="section-heading center">
        <p class="eyebrow">Featured projects</p>
        <h2>12 reference projects across railways, substations, solar, hydropower and industrial plants</h2>
        <p>
          These references show the application range of Qixing high-voltage bushings from 2015 to 2023.
          Click any project for full details and on-site images.
        </p>
        <a class="button primary orange" href="/contact/">Request Similar Reference →</a>
      </div>
      <div class="project-grid">
        {allProjects.map((item) => (
          <a href={`/applications/${item.slug}/`} class="project-card-link">
            <article class="project-card">
              <div class="project-card-img">
                <img
                  src={`/assets/projects/${item.images[0]}`}
                  alt={item.title}
                  loading="lazy"
                />
              </div>
              <div class="project-card-body">
                <h3>{item.title}</h3>
                <span class="project-customer">{item.customer}</span>
                <strong class="project-product">{item.products} | {item.date}</strong>
                <p>{item.note}</p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>

    <section class="section applications-band">
      <div class="section-heading">
        <p class="eyebrow">Application scenarios</p>
        <h2>Where Qixing bushings are typically used</h2>
      </div>
      <div class="case-grid case-grid-four">
        {applicationCards.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section trusted">
      <div class="section-heading center">
        <p class="eyebrow">Customer trust</p>
        <h2>Supplied to transformer OEMs, grid equipment makers and project owners</h2>
      </div>
      <div class="customer-row">
        {customers.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="cta-panel">
      <div>
        <p class="eyebrow">Project inquiry</p>
        <h2>Have a similar project?</h2>
        <p>Send your specs — Mark Yan will provide a reference case and quotation.</p>
        <div class="contact-card">
          <div class="contact-avatar" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 12.5a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 2c-4.4 0-8 2.4-8 5.3 0 .7.5 1.2 1.2 1.2h13.6c.7 0 1.2-.5 1.2-1.2 0-2.9-3.6-5.3-8-5.3Z" fill="currentColor"/>
            </svg>
          </div>
          <div>
            <strong>{company.contact.person}</strong>
            <span>{company.contact.title}</span>
            <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">{company.contact.phone} (WhatsApp)</a>
            <a href={`mailto:${company.contact.email}`}>{company.contact.email}</a>
          </div>
        </div>
      </div>
      <a class="button primary orange" href="/contact/">Send Project Specs →</a>
    </section>
  </main>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .project-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .project-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .project-card-link:hover .project-card {
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    transform: translateY(-2px);
  }

  .project-card-img {
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: #f0f0f0;
  }
  .project-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-card-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .project-card-body h3 {
    font-size: 1.05rem;
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }
  .project-customer {
    font-size: 0.85rem;
    color: #666;
  }
  .project-product {
    display: block;
    font-size: 0.85rem;
    color: #333;
    margin: 0.5rem 0;
  }
  .project-card-body p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
    flex: 1;
  }
  /* Force 4 columns for application scenario cards */
  .case-grid-four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  @media (max-width: 900px) {
    .case-grid-four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .case-grid-four {
      grid-template-columns: 1fr;
    }
  }
</style>
