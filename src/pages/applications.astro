---
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { applicationCards, company } from "../data/site.js";

const trustStats = [
  { value: "50,000+", label: "Installations" },
  { value: "12+", label: "Years Operation" },
  { value: "75%", label: "Railway Market Share" },
  { value: "30+", label: "Countries" },
];

const featuredProjects = [
  {
    name: "Lhasa-Nyingchi Railway",
    customer: "Yunnan Transformer",
    product: "220kV Transformer Bushing",
    date: "2020",
    tag: "Railway",
    note: "Applied in high-altitude railway power infrastructure where insulation stability and long-term operation are critical.",
  },
  {
    name: "Sichuan Batang 500kV Substation (State Grid)",
    customer: "Shandong Dachi Electric",
    product: "252kV Transformer Bushing",
    date: "2017",
    tag: "Substation",
    note: "Supplied for a 500kV grid node requiring reliable transformer-side bushing performance under utility operation.",
  },
  {
    name: "Gansu Longyuan 500MW Solar + Storage",
    customer: "Xi'an XD Transformer",
    product: "330kV Transformer Bushing",
    date: "2023",
    tag: "Solar",
    note: "Used in renewable energy transmission equipment for a large solar-plus-storage project with high-voltage connection needs.",
  },
  {
    name: "Chengdu-Chongqing High-Speed Railway",
    customer: "TBEA Xinjiang",
    product: "252kV Transformer Bushing",
    date: "2019",
    tag: "Railway",
    note: "Railway traction power equipment demands stable insulation, compact installation and dependable field service life.",
  },
  {
    name: "Jiangxi Jiepai Hydropower Station",
    customer: "Jiangsu Yawei Transformer",
    product: "126kV Oil-SF6 Bushing",
    date: "2015",
    tag: "Hydropower",
    note: "Selected for hydropower transformer equipment where sealed interfaces and long-term grid operation matter.",
  },
  {
    name: "Shaanxi Linyou 350MW Coal Power Plant",
    customer: "Xi'an XD Switchgear",
    product: "330kV GIS Bushing",
    date: "2018",
    tag: "Substation",
    note: "GIS bushing application for power plant switchgear and high-voltage transmission interface equipment.",
  },
  {
    name: "Ningxia Dadi Tire Project",
    customer: "Pinggao Group",
    product: "126kV GIS Bushing",
    date: "2015",
    tag: "Industrial",
    note: "Industrial power distribution projects need robust GIS interfaces for reliable plant-side electrical operation.",
  },
];

const customers = [
  "TBEA",
  "XD Electric",
  "Baoding Tianwei Baobian",
  "Pinggao Group",
  "Yunnan Transformer",
  "Shandong Dachi",
  "Jiangsu Yawei",
  "State Grid",
  "Longyuan Power",
];
---

<BaseLayout title={`Reference Projects | ${company.name}`}>
  <main>
    <PageHero
      eyebrow="Reference Projects"
      title="Proven in Critical Power Infrastructure Worldwide"
      text="50,000+ bushings installed across railways, substations, solar farms, hydropower and industrial plants. Trusted by TBEA, XD Electric, State Grid and more."
      image="/assets/application-transformer-sites.jpg"
    />

    <section class="trust-row" aria-label="Reference project trust signals">
      {trustStats.map((item) => (
        <article>
          <div>
            <strong>{item.value}</strong>
            <p>{item.label}</p>
          </div>
        </article>
      ))}
    </section>

    <section class="section cases-preview">
      <div class="section-heading center">
        <p class="eyebrow">Featured projects</p>
        <h2>Installed in railways, substations, renewable energy and industrial plants</h2>
        <p>
          These references show the application range of Qixing high-voltage bushings from 2015 to 2023.
          Share your project rating and we can match the closest reference case for engineering review.
        </p>
        <a class="button primary orange" href="/contact/">Request Similar Reference →</a>
      </div>
      <div class="project-grid">
        {featuredProjects.map((item) => (
          <article>
            <img src="/assets/application-transformer-sites.jpg" alt="" />
            <div>
              <h3>{item.name}</h3>
              <span>{item.customer}</span>
              <strong>{item.product} | Commissioned {item.date}</strong>
              <p>{item.note}</p>
              <div class="tag-list">
                <span>{item.tag}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
      <a class="text-link" href="/contact/">Discuss Your Project →</a>
    </section>

    <section class="section applications-band">
      <div class="section-heading">
        <p class="eyebrow">Application scenarios</p>
        <h2>Where Qixing bushings are typically used</h2>
      </div>
      <div class="case-grid">
        {applicationCards.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section trusted">
      <div class="section-heading center">
        <p class="eyebrow">Customer trust</p>
        <h2>Supplied to transformer OEMs, grid equipment makers and project owners</h2>
      </div>
      <div class="customer-row">
        {customers.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="cta-panel">
      <div>
        <p class="eyebrow">Project inquiry</p>
        <h2>Have a similar project?</h2>
        <p>Send your specs — Mark Yan will provide a reference case and quotation.</p>
        <div class="contact-card">
          <div class="contact-avatar" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d="M12 12.5a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 2c-4.4 0-8 2.4-8 5.3 0 .7.5 1.2 1.2 1.2h13.6c.7 0 1.2-.5 1.2-1.2 0-2.9-3.6-5.3-8-5.3Z" fill="currentColor"/>
            </svg>
          </div>
          <div>
            <strong>{company.contact.person}</strong>
            <span>{company.contact.title}</span>
            <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">{company.contact.phone} (WhatsApp)</a>
            <a href={`mailto:${company.contact.email}`}>{company.contact.email}</a>
          </div>
        </div>
      </div>
      <a class="button primary orange" href="/contact/">Send Project Specs →</a>
    </section>
  </main>
</BaseLayout>
