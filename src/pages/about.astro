const applications = [
  {
    title: "Power Transformers",
    image: aboutMedia.projects[0],
    text: "Bushings for oil-immersed power transformers from 12kV to 550kV in utility substations and industrial plants.",
  },
  {
    title: "GIS Connections",
    image: aboutMedia.projects[1],
    text: "Oil-SF6 and GIS bushings for compact switchgear interfaces and transformer-to-GIS transitions.",
  },
