const factoryStats = [
  {
    value: "9,950 m²",
    label: "Manufacturing Facility",
    desc: "Covered production area with casting, winding, assembly and testing workshops",
  },
  {
    value: "100+",
    label: "Skilled Workforce",
    desc: "Engineers and technicians with an average of 7+ years in HV bushing manufacturing",
  },
  {
    value: "RMB 300M",
    label: "Annual Capacity",
    desc: "Production capacity covering 12kV–550kV RIP/RIF bushing full voltage series",
