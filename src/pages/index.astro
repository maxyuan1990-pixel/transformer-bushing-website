---
import BaseLayout from "../layouts/BaseLayout.astro";
import { company } from "../data/site.js";

const trustStats = [
  { icon: "factory", value: "50,000+", label: "Bushings Delivered" },
  { icon: "calendar", value: "12", label: "Years of Manufacturing Excellence" },
  { icon: "rail", value: "75%", label: "Railway Market Share in China" },
];

const advantages = [
  { icon: "fire", title: "Fire-safe", text: "No oil, no explosion risk" },
  { icon: "tool", title: "Maintenance-free", text: "Zero field maintenance" },
  { icon: "scale", title: "Lightweight", text: "30-50% lighter than porcelain" },
  { icon: "angle", title: "Any Angle", text: "Horizontal, vertical, or tilted installation" },
  { icon: "leaf", title: "Eco-friendly", text: "No SF6, no oil leakage" },
];

const products = [
  ["Oil-Air Transformer Bushing", "12kV-550kV / 1A-8000A"],
  ["Oil-SF6 Transformer Bushing", "40.5kV-550kV / 630A-8000A"],
  ["Oil-Oil Transformer Bushing", "40.5kV-550kV / 630A-8000A"],
  ["High Current Transformer Bushing", "24kV-40.5kV / 12,500A-40,000A"],
  ["GIS Outlet Bushing", "40.5kV-550kV / 1000A-8000A"],
  ["Wall Bushing", "24kV-550kV / 630A-8000A"],
];

const cases = [
  {
    name: "Lhasa-Nyingchi Railway",
    country: "Tibet, China",
    model: "220kV Transformer Bushing",
    result: "Reliable dry-type insulation performance for high-altitude railway power infrastructure.",
  },
  {
    name: "Sichuan Batang 500kV Substation",
    country: "State Grid",
    model: "252kV Bushing",
    result: "Applied in a critical 500kV grid node requiring stable transformer operation.",
  },
  {
    name: "Gansu 500MW Solar + Storage Project",
    country: "Longyuan Power",
    model: "330kV Bushing",
    result: "Supported renewable energy transmission with high-voltage bushing equipment.",
  },
];

const certifications = ["ISO 9001", "ISO 14001", "ISO 45001", "CE", "IEC 60137", "DL/T 1001"];
const customers = ["TBEA", "XD Electric", "Baoding Tianwei Baobian", "Pinggao Group", "Yunnan Transformer"];
const factoryStats = [
  "9,950 m2 Manufacturing Facility",
  "100+ Skilled Employees",
  "RMB 300M Annual Production Capacity",
  "4,917+ Railway Bushings in Service",
];
---

<BaseLayout
  title={`${company.name} | Dry-type Bushing Specialist`}
  description="RIP/RIF capacitive dry-type bushings from 12kV to 550kV for transformer, GIS, wall and railway power projects."
>
  <main>
    <section class="conversion-hero">
      <img src="/assets/hv-bushing-transformer-yard.jpg" alt="" />
      <div class="hero-shade"></div>
      <div class="conversion-hero-content">
        <h1>Dry-type Bushing Specialist | 50,000+ Global Installations</h1>
        <p>
          RIP/RIF Capacitive Bushings - 12kV to 550kV - IEC 60137 &amp; GB/T 4109 Certified
        </p>
        <div class="hero-actions">
          <a class="button primary orange hero-primary" href="#inquiry">Request a Quote →</a>
          <button class="button outline-light" popovertarget="catalog-popover" type="button">
            Download Product Catalog →
          </button>
        </div>
      </div>
    </section>

    <div class="catalog-popover" id="catalog-popover" popover>
      <button class="popover-close" popovertarget="catalog-popover" popovertargetaction="hide" type="button">x</button>
      <p class="eyebrow">Product catalog</p>
      <h2>Get the bushing catalog</h2>
      <p>Leave your email and our sales engineer will send the catalog after contact details are confirmed.</p>
      <form class="mini-form">
        <input type="email" placeholder="Business email *" required />
        <button class="button primary orange" type="submit">Request Catalog</button>
      </form>
    </div>

    <section class="trust-row" aria-label="Factory trust numbers">
      {trustStats.map((item) => (
        <article>
          <span class={`line-icon ${item.icon}`} aria-hidden="true"></span>
          <div>
            <strong>{item.value}</strong>
            <p>{item.label}</p>
          </div>
        </article>
      ))}
    </section>

    <section class="section tech-choice">
      <div>
        <p class="eyebrow">Why dry-type bushings</p>
        <h2>Safer insulation for modern transformer and grid equipment</h2>
        <p>
          RIP/RIF dry-type capacitive bushings replace oil-paper and porcelain-heavy designs with a
          compact solid insulation system. With no internal oil or SF6, the structure reduces fire,
          explosion and leakage risk while improving installation flexibility. The lighter body helps
          transformer OEMs simplify handling, transport and site assembly. For utilities and EPC
          projects, dry-type bushings provide cleaner lifecycle performance, lower maintenance burden
          and stable operation in horizontal, vertical or tilted mounting positions.
        </p>
        <a class="button primary orange" href="/products/">See Technical Comparison →</a>
      </div>
      <div class="advantage-grid">
        {advantages.map((item) => (
          <article>
            <span class={`line-icon ${item.icon}`} aria-hidden="true"></span>
            <strong>{item.title}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section product-range">
      <div class="section-heading center">
        <p class="eyebrow">Product Center</p>
        <h2>Our Product Range</h2>
      </div>
      <div class="conversion-product-grid">
        {products.map(([name, range], index) => (
          <article>
            <span class="product-icon" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
            <h3>{name}</h3>
            <p>{range}</p>
            <a href="/products/">View Details →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section cases-preview">
      <div class="section-heading center">
        <p class="eyebrow">Reference Projects</p>
        <h2>Proven in Critical Projects</h2>
      </div>
      <div class="project-grid">
        {cases.map((item) => (
          <article>
            <img src="/assets/application-transformer-sites.jpg" alt="" />
            <div>
              <h3>{item.name}</h3>
              <span>{item.country}</span>
              <strong>{item.model}</strong>
              <p>{item.result}</p>
            </div>
          </article>
        ))}
      </div>
      <a class="text-link" href="/applications/">View All Reference Projects →</a>
    </section>

    <section class="section trusted">
      <div class="section-heading center">
        <p class="eyebrow">Certifications and customers</p>
        <h2>Trusted By Industry Leaders</h2>
      </div>
      <div class="badge-row">
        {certifications.map((item) => <span>{item}</span>)}
      </div>
      <div class="customer-row">
        {customers.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="section factory-overview">
      <div class="factory-images">
        <img src="/assets/factory-testing-line.jpg" alt="High voltage bushing factory testing line" />
        <img src="/assets/inspection-reports.jpg" alt="Inspection reports and certificates" />
        <img src="/assets/product-structure-table.jpg" alt="Product structure and technical table" />
      </div>
      <div>
        <p class="eyebrow">Factory overview</p>
        <h2>Manufacturing capability for large-scale power projects</h2>
        <div class="factory-stat-list">
          {factoryStats.map((item) => <strong>{item}</strong>)}
        </div>
        <a class="button primary orange" href="/about/">Virtual Factory Tour →</a>
      </div>
    </section>

    <section class="final-inquiry" id="inquiry">
      <div class="section-heading center">
        <p class="eyebrow">Fast engineering response</p>
        <h2>Get Your Bushing Solution</h2>
        <p>Tell us your voltage, current, and application - we'll respond within 24 hours.</p>
      </div>
      <div class="contact-card">
        <div class="contact-avatar" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 12.5a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 2c-4.4 0-8 2.4-8 5.3 0 .7.5 1.2 1.2 1.2h13.6c.7 0 1.2-.5 1.2-1.2 0-2.9-3.6-5.3-8-5.3Z" fill="currentColor"/>
          </svg>
        </div>
        <div>
          <strong>{company.contact.person}</strong>
          <span>{company.contact.title}</span>
          <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">📞 {company.contact.phone} (Phone &amp; WhatsApp)</a>
          <a href={`mailto:${company.contact.email}`}>✉️ {company.contact.email}</a>
        </div>
      </div>
      <form class="inquiry-line" data-inquiry-form>
        <input type="email" placeholder="Email *" required />
        <input type="text" placeholder="Message" />
        <button class="button primary orange" type="submit">Submit Inquiry →</button>
      </form>
      <p class="inquiry-success" data-inquiry-success hidden>Thank you! We'll respond within 24 hours.</p>
      <p class="contact-line">
        <a href="/contact/">Contact</a> | <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">{company.contact.whatsapp}</a> | <a href={`mailto:${company.contact.email}`}>{company.contact.email}</a>
      </p>
    </section>

    <div class="floating-actions" aria-label="Quick contact actions">
      <a class="whatsapp-float-wrap" href={company.contact.whatsappUrl} aria-label="Chat on WhatsApp">
        <span class="whatsapp-bubble" data-whatsapp-bubble>Chat on WhatsApp 💬</span>
        <span class="float-whatsapp" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" fill="currentColor"/>
          </svg>
        </span>
      </a>
    </div>

    <script>
      const bubble = document.querySelector("[data-whatsapp-bubble]");
      if (bubble) {
        window.setTimeout(() => {
          bubble.classList.add("is-closed");
        }, 8000);
      }

      const inquiryForm = document.querySelector("[data-inquiry-form]");
      const inquirySuccess = document.querySelector("[data-inquiry-success]");
      if (inquiryForm && inquirySuccess) {
        inquiryForm.addEventListener("submit", (event) => {
          event.preventDefault();
          inquirySuccess.hidden = false;
          inquiryForm.reset();
        });
      }
    </script>
  </main>
</BaseLayout>
