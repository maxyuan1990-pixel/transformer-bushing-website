---
import BaseLayout from "./BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { company } from "../data/site.js";

export interface Props {
  title: string;
  productCode: string;
  voltage: string;
  current: string;
  description: string;
  mainImage: string;
  galleryImages?: string[];
  hasSlideEnlarge?: boolean;
}

const {
  title,
  productCode,
  voltage,
  current,
  description,
  mainImage,
  galleryImages = [],
} = Astro.props;

const allProducts = [
  { name: "Oil-Air Transformer Bushing", href: "/products/oil-air-bushing/", img: "product-oil-air-bushing.webp" },
  { name: "Oil-SF6 Transformer Bushing", href: "/products/oil-sf6-bushing/", img: "product-oil-sf6-bushing.webp" },
  { name: "Oil-Oil Transformer Bushing", href: "/products/oil-oil-bushing/", img: "product-oil-oil-bushing.webp" },
  { name: "High Current Transformer Bushing", href: "/products/high-current-bushing/", img: "product-high-current-bushing.webp" },
  { name: "GIS Outlet Bushing", href: "/products/gis-bushing/", img: "product-gis-bushing.webp" },
  { name: "Wall Bushing", href: "/products/wall-bushing/", img: "product-wall-bushing.webp" },
];
---

<BaseLayout title={`${title} | ${company.shortName}`}>
  <main>
    <PageHero
      eyebrow="Products"
      title={title}
      text={`${productCode} | ${voltage} | ${current}`}
    />

    <!-- Product Detail Section -->
    <section class="section product-detail-layout">
      <div class="product-detail-grid">
        <!-- Sidebar -->
        <aside class="product-sidebar">
          <div class="sidebar-card">
            <div class="sidebar-search">
              <input type="text" placeholder="Search Products" disabled />
              <button type="button" aria-label="Search">🔍</button>
            </div>
            <strong class="sidebar-title">Our Products</strong>
            <nav class="sidebar-nav">
              {allProducts.map((p) => (
                <a href={p.href} class:list={["sidebar-link", { active: p.href === Astro.url.pathname }]}>
                  {p.name}
                </a>
              ))}
            </nav>
            <strong class="sidebar-title">Quick Inquiry</strong>
            <div class="sidebar-contact">
              <span>📞 {company.contact.phone}</span>
              <span>✉️ {company.contact.email}</span>
            </div>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="product-main">
          <!-- Image + Info Row -->
          <div class="product-info-row">
            <div class="product-gallery">
              <div class="gallery-main">
                <img
                  src={`/assets/qxelectric/${mainImage}`}
                  alt={title}
                  width="600"
                  height="450"
                />
              </div>
              {galleryImages.length > 0 && (
                <div class="gallery-thumbs">
                  {galleryImages.map((img, i) => (
                    <div class="gallery-thumb">
                      <img
                        src={`/assets/qxelectric/${img}`}
                        alt={`${title} view ${i + 1}`}
                        width="95"
                        height="72"
                        loading="lazy"
                      />
                    </div>
                  ))}
                </div>
              )}
            </div>
            <div class="product-meta">
              <h1 class="product-title">{title}</h1>
              <div class="product-specs">
                {description.split("\n").map((line) => <p>{line}</p>)}
              </div>
              <div class="product-contact-links">
                <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">
                  📞 {company.contact.phone}
                </a>
                <a href={`mailto:${company.contact.email}`}>
                  ✉️ {company.contact.email}
                </a>
                <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">
                  💬 WhatsApp
                </a>
              </div>
              <div class="product-cta-row">
                <a class="button primary orange" href={company.contact.whatsappUrl} target="_blank" rel="noopener">
                  WhatsApp
                </a>
                <a class="button primary orange" href={`mailto:${company.contact.email}`}>
                  Email Inquiry
                </a>
              </div>
            </div>
          </div>

          <!-- Content Sections (filled by page) -->
          <div class="product-content">
            <slot />
          </div>
        </div>
      </div>
    </section>

    <!-- Related Products -->
    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Product Recommendations</p>
        <h2>Explore Other Bushing Models</h2>
      </div>
      <div class="product-grid">
        {allProducts.filter(p => p.href !== Astro.url.pathname).map((p) => (
          <article class="product-card flat">
            <div>
              <picture>
                <source srcset={`/assets/${p.img}`} type="image/webp" />
                <img
                  src={`/assets/${p.img.replace('.webp', '.png')}`}
                  alt={p.name}
                  loading="lazy"
                  width="600"
                  height="400"
                />
              </picture>
              <h3>{p.name}</h3>
              <a class="button secondary" href={p.href}>View Details →</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Inquiry -->
    <section class="final-inquiry">
      <div class="section-heading center">
        <p class="eyebrow">Model selection support</p>
        <h2>Need help with {title}?</h2>
        <p>Send your voltage, current and application — {company.contact.person} will reply within 24 hours.</p>
      </div>
      <div class="contact-card">
        <div class="contact-avatar" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 12.5a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 2c-4.4 0-8 2.4-8 5.3 0 .7.5 1.2 1.2 1.2h13.6c.7 0 1.2-.5 1.2-1.2 0-2.9-3.6-5.3-8-5.3Z" fill="currentColor"/>
          </svg>
        </div>
        <div>
          <strong>{company.contact.person}</strong>
          <span>{company.contact.title}</span>
          <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">{company.contact.phone} (WhatsApp)</a>
          <a href={`mailto:${company.contact.email}`}>{company.contact.email}</a>
        </div>
      </div>
      <form class="inquiry-line" data-product-inquiry-form>
        <input type="email" placeholder="Your Email *" required />
        <input type="text" placeholder="Tell us your voltage, current and application" />
        <button class="button primary orange" type="submit">Get Recommendation →</button>
      </form>
      <p class="inquiry-success" data-product-inquiry-success hidden>Thank you! We'll respond within 24 hours.</p>
    </section>

    <script>
      const form = document.querySelector("[data-product-inquiry-form]");
      const success = document.querySelector("[data-product-inquiry-success]");
      if (form && success) {
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          if (success instanceof HTMLElement) {
            success.hidden = false;
          }
          if (form instanceof HTMLFormElement) {
            form.reset();
          }
        });
      }
    </script>
  </main>
</BaseLayout>

<style>
  .product-detail-layout {
    padding-top: clamp(24px, 3vw, 48px);
    padding-bottom: clamp(40px, 5vw, 80px);
  }

  .product-detail-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: clamp(28px, 4vw, 48px);
    align-items: start;
  }

  .product-sidebar {
    position: sticky;
    top: 100px;
  }

  .sidebar-card {
    padding: 28px;
    border-radius: 8px;
    background: var(--white);
    box-shadow: 0 0 20px 3px rgba(235, 235, 235, 0.81);
  }

  .sidebar-search {
    display: flex;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .sidebar-search input {
    flex: 1;
    border: 0;
    padding: 12px 14px;
    background: rgba(240, 239, 243, 0.57);
    font: inherit;
    font-size: 0.95rem;
  }

  .sidebar-search button {
    border: 0;
    background: var(--blue);
    color: var(--white);
    padding: 12px 14px;
    cursor: pointer;
  }

  .sidebar-title {
    display: block;
    font-size: 1.35rem;
    color: var(--dark);
    margin: 24px 0 12px;
    padding-left: 12px;
  }

  .sidebar-nav {
    display: grid;
    gap: 4px;
  }

  .sidebar-link {
    display: block;
    padding: 12px 14px;
    border-radius: 6px;
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--ink);
    background: rgba(242, 242, 242, 1);
    transition: all 0.2s;
  }

  .sidebar-link:hover,
  .sidebar-link.active {
    background: var(--blue);
    color: var(--white);
  }

  .sidebar-contact {
    display: grid;
    gap: 8px;
    padding: 12px;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .product-main {
    min-width: 0;
  }

  .product-info-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 40px);
    margin-bottom: 40px;
  }

  .product-gallery {
    display: grid;
    gap: 12px;
  }

  .gallery-main {
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: var(--white);
  }

  .gallery-main img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gallery-thumbs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
  }

  .gallery-thumb {
    flex: 0 0 auto;
    width: 95px;
    height: 72px;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .gallery-thumb:hover {
    border-color: var(--blue);
  }

  .product-meta {
    display: grid;
    gap: 16px;
    align-content: start;
  }

  .product-title {
    font-size: 1.8rem;
    color: var(--blue);
    margin: 0;
  }

  .product-specs {
    color: var(--ink);
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .product-specs p {
    margin: 0;
    color: var(--ink);
  }

  .product-contact-links {
    display: grid;
    gap: 8px;
  }

  .product-contact-links a {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--blue);
    font-weight: 800;
    font-size: 1rem;
  }

  .product-contact-links a:hover {
    text-decoration: underline;
  }

  .product-cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .product-content {
    border-top: 1px solid var(--line);
    padding-top: 32px;
  }

  .tech-section-title {
    display: inline-block;
    background: rgba(217, 217, 217, 0.35);
    color: var(--blue);
    font-weight: bold;
    font-size: 1.45rem;
    padding: 12px 20px;
    margin: 32px 0 16px;
    width: 100%;
  }

  .tech-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .tech-table th {
    background: var(--dark-2);
    color: var(--white);
    padding: 10px 12px;
    text-align: center;
    font-weight: 800;
  }

  .tech-table td {
    padding: 8px 10px;
    border: 1px solid var(--line);
    text-align: center;
  }

  .tech-table tr:nth-child(even) td {
    background: rgba(0, 0, 0, 0.02);
  }

  .tech-diagram {
    text-align: center;
    margin: 16px 0;
  }

  .tech-diagram img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .content-block {
    margin-bottom: 20px;
    line-height: 1.8;
    color: var(--ink);
  }

  .content-block p {
    margin: 0 0 8px;
  }

  .content-block strong {
    color: var(--dark);
  }

  .content-block ul {
    margin: 8px 0 0 20px;
    color: var(--muted);
  }

  @media (max-width: 1080px) {
    .product-detail-grid {
      grid-template-columns: 1fr;
    }

    .product-info-row {
      grid-template-columns: 1fr;
    }

    .product-sidebar {
      position: static;
    }
  }

  @media (max-width: 680px) {
    .product-cta-row {
      flex-direction: column;
    }
  }
</style>
