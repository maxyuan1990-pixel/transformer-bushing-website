---
import "../styles/global.css";
import { company } from "../data/site.js";

const {
  title = `${company.name} | ${company.tagline}`,
  description = "High voltage bushing manufacturer for transformer, GIS, wall and oil-SF6 applications.",
} = Astro.props;

const currentPath = Astro.url.pathname;

const layoutNavItems = [
  { label: "Home", href: "/" },
  { label: "Products", href: "/products/", children: [
    { label: "RIP/RIF Oil-Air Transformer Bushing", href: "/products/oil-air-bushing/" },
    { label: "RIP/RIF Oil-SF6 Transformer Bushing", href: "/products/oil-sf6-bushing/" },
    { label: "RIP/RIF Oil-Oil Transformer Bushing", href: "/products/oil-oil-bushing/" },
    { label: "RIP/RIF High Current Transformer Bushing", href: "/products/high-current-bushing/" },
    { label: "RIP/RIF GIS Outlet Bushing", href: "/products/gis-bushing/" },
    { label: "RIP/RIF Wall Bushing", href: "/products/wall-bushing/" },
  ]},
  { label: "Reference Projects", href: "/applications/" },
  { label: "Downloads", href: "/downloads/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="topbar">
      <div class="utility">
        <span>{company.contact.person}, {company.contact.title}</span>
        <a class="whatsapp-link" href={company.contact.whatsappUrl} target="_blank" rel="noopener">
          <svg class="whatsapp-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
          </svg>
          {company.contact.phone}
        </a>
        <a class="email-link" href={`mailto:${company.contact.email}`}>
          <svg class="email-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          {company.contact.email}
        </a>
      </div>
      <nav class="navbar" aria-label="Main navigation">
        <a class="brand" href="/">
          <img class="brand-logo" src="/assets/qixing-logo.png" alt="Qixing High Voltage" />
        </a>
        <div class="nav-links">
          {layoutNavItems.map((item) => (
            item.children ? (
              <div class="nav-dropdown">
                <a class={currentPath.startsWith(item.href) ? "active" : ""} href={item.href}>
                  {item.label} <span class="dropdown-arrow">▾</span>
                </a>
                <div class="dropdown-menu">
                  {item.children.map((child) => (
                    <a href={child.href} class:list={["dropdown-link", { active: currentPath === child.href }]}>
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a class={currentPath === item.href ? "active" : ""} href={item.href}>
                {item.label}
              </a>
            )
          ))}
        </div>
        <button class="hamburger" aria-label="Open menu" aria-expanded="false" data-menu-toggle>
          <span></span><span></span><span></span>
        </button>
        <button class="nav-cta" popovertarget="quote-popover">Get a Quote</button>
      </nav>
      <div class="mobile-nav" data-mobile-nav inert>
        <div class="mobile-nav-header">
          <strong>Menu</strong>
          <button class="mobile-nav-close" aria-label="Close menu" data-menu-close>&times;</button>
        </div>
        <nav class="mobile-nav-links">
          <a href="/">Home</a>
          <div class="mobile-accordion">
            <button class="mobile-accordion-trigger" data-accordion-trigger>Products ▾</button>
            <div class="mobile-accordion-panel">
              <a href="/products/">All Products</a>
              <a href="/products/oil-air-bushing/">Oil-Air Transformer Bushing</a>
              <a href="/products/oil-sf6-bushing/">Oil-SF6 Transformer Bushing</a>
              <a href="/products/oil-oil-bushing/">Oil-Oil Transformer Bushing</a>
              <a href="/products/high-current-bushing/">High Current Transformer Bushing</a>
              <a href="/products/gis-bushing/">GIS Outlet Bushing</a>
              <a href="/products/wall-bushing/">Wall Bushing</a>
            </div>
          </div>
          <a href="/applications/">Reference Projects</a>
          <a href="/downloads/">Downloads</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        </nav>
      </div>
    </header>

    <div class="quote-popover" id="quote-popover" popover>
      <button class="popover-close" popovertarget="quote-popover" popovertargetaction="hide" type="button">&times;</button>
      <p class="eyebrow">Fast response</p>
      <h2>Get a Quote</h2>
      <p>Tell us your voltage, current and application — Mark will reply within 24 hours.</p>
      <form class="mini-form" data-quote-form data-redirect="/thanks/">
        <input type="text" placeholder="Name" />
        <input type="email" placeholder="Email *" required />
        <input type="text" placeholder="WhatsApp" />
        <input type="text" placeholder="Company" />
        <textarea rows="4" placeholder="Tell us about your project — voltage, current, quantity, application..."></textarea>
        <button class="button primary orange" type="submit">Send Inquiry →</button>
      </form>
    </div>

    <slot />
    <footer class="footer">
      <div>
        <strong>{company.name}</strong>
        <p>High voltage bushings for transformers, GIS, wall penetration and power grid projects.</p>
      </div>
      <div class="footer-links">
        <a href="/products/">Products</a>
        <a href="/applications/">Reference Projects</a>
        <a href="/downloads/">Downloads</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
      </div>
      <address>
        <span>Contact: {company.contact.person}, {company.contact.title}</span>
        <a href={company.contact.whatsappUrl} target="_blank" rel="noopener">Tel/WhatsApp: {company.contact.phone}</a>
        <a href={`mailto:${company.contact.email}`}>Email: {company.contact.email}</a>
        <span>Address: {company.contact.address}</span>
      </address>
    </footer>
    <div class="floating-actions" aria-label="Quick contact actions">
      <span class="whatsapp-float-wrap">
        <span class="whatsapp-bubble" data-quote-bubble>Get a Quote 📋</span>
        <button class="float-email" popovertarget="quote-popover" aria-label="Get a Quote">
          <svg viewBox="0 0 24 24">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z" fill="currentColor"/>
          </svg>
        </button>
      </span>
      <a class="whatsapp-float-wrap" href={company.contact.whatsappUrl} target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
        <span class="whatsapp-bubble" data-whatsapp-bubble>Chat on WhatsApp 💬</span>
        <span class="float-whatsapp" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" fill="currentColor"/>
          </svg>
        </span>
      </a>
    </div>

    <script>
      const bubble = document.querySelector("[data-whatsapp-bubble]");
      if (bubble) {
        window.setTimeout(() => {
          bubble.classList.add("is-closed");
        }, 8000);
      }

      const quoteBubble = document.querySelector("[data-quote-bubble]");
      if (quoteBubble) {
        window.setTimeout(() => {
          quoteBubble.classList.add("is-closed");
        }, 10000);
      }

      const toggle = document.querySelector("[data-menu-toggle]");
      const drawer = document.querySelector("[data-mobile-nav]");
      const close = document.querySelector("[data-menu-close]");
      const body = document.body;

      const closeDrawer = () => {
        drawer?.setAttribute("inert", "");
        drawer?.classList.remove("open");
        toggle?.setAttribute("aria-expanded", "false");
        body.style.overflow = "";
      };

      toggle?.addEventListener("click", () => {
        const open = drawer?.hasAttribute("inert");
        if (open && drawer) {
          drawer.removeAttribute("inert");
          drawer.classList.add("open");
          toggle.setAttribute("aria-expanded", "true");
          body.style.overflow = "hidden";
        }
      });

      close?.addEventListener("click", closeDrawer);

      document.querySelectorAll("[data-mobile-nav] a").forEach((link) => {
        link.addEventListener("click", closeDrawer);
      });

      document.querySelectorAll("[data-accordion-trigger]").forEach((btn) => {
        btn.addEventListener("click", () => {
          btn.classList.toggle("expanded");
          btn.nextElementSibling?.classList.toggle("open");
        });
      });

      /* Quote popover form */
      import("../scripts/contact-form.js").then(({ initContactForm }) => {
        const qf = document.querySelector("[data-quote-form]");
        if (qf) initContactForm(qf, null);
      });
    </script>
  </body>
</html>
